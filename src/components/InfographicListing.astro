---
import type { Infographic } from '../types';

interface Props {
  infographics: Infographic[];
  page: number;
  totalPages: number;
}

const { infographics, page, totalPages } = Astro.props;

function pageHref(p: number): string {
  return p <= 1 ? '/infographics' : `/infographics/page/${p}`;
}
---

{infographics.length > 0 ? (
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {infographics.map((item) => (
      <a
        href={`/infographic/${item.slug}`}
        class="group block bg-zinc-900/40 border border-white/[0.06] hover:border-white/[0.12] rounded-2xl overflow-hidden transition-all duration-300 hover:bg-zinc-800/40 hover:-translate-y-1"
      >
        <div class="relative w-full bg-zinc-800 overflow-hidden aspect-[4/5]">
          {item.imageUrl && (
            <img
              src={item.imageUrl}
              alt={item.altText || item.title}
              loading="lazy"
              decoding="async"
              width={item.imageWidth || 800}
              height={item.imageHeight || 1000}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          )}
        </div>
        <div class="p-5 space-y-2">
          <h3 class="font-display text-zinc-200 font-medium tracking-tight line-clamp-2 group-hover:text-white transition-colors">
            {item.title}
          </h3>
          {item.description && (
            <p class="text-zinc-500 text-sm line-clamp-2">{item.description}</p>
          )}
          {item.tags && item.tags.length > 0 && (
            <div class="flex flex-wrap items-center gap-1.5 pt-1">
              {item.tags.slice(0, 3).map((tag) => (
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-white/5 border border-white/5 text-zinc-500">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>
      </a>
    ))}
  </div>
) : (
  <p class="text-zinc-500">No infographics yet — check back soon.</p>
)}

{totalPages > 1 && (
  <nav aria-label="Pagination" class="flex items-center justify-center gap-2 pt-8">
    {page > 1 && (
      <a
        href={pageHref(page - 1)}
        rel="prev"
        class="px-3 py-1.5 text-xs border border-white/10 hover:border-white/20 hover:bg-white/5 rounded-lg text-zinc-300 transition-colors"
      >
        ← Previous
      </a>
    )}
    {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
      <a
        href={pageHref(p)}
        aria-current={p === page ? 'page' : undefined}
        class={`px-3 py-1.5 text-xs rounded-lg transition-colors ${
          p === page
            ? 'bg-white/10 text-zinc-100 border border-white/10'
            : 'border border-white/5 text-zinc-500 hover:text-zinc-200 hover:bg-white/5'
        }`}
      >
        {p}
      </a>
    ))}
    {page < totalPages && (
      <a
        href={pageHref(page + 1)}
        rel="next"
        class="px-3 py-1.5 text-xs border border-white/10 hover:border-white/20 hover:bg-white/5 rounded-lg text-zinc-300 transition-colors"
      >
        Next →
      </a>
    )}
  </nav>
)}
