---
import MainLayout from '../layouts/MainLayout.astro';
import HomeContent from '../components/HomeContent';
import { rowToSession, SESSION_SELECT_WITH_AUTHOR } from '../lib/db';
import type { Session } from '../types';

const db = Astro.locals.runtime.env.DB;
const [sessionsRes, videosRes] = await Promise.all([
  db.prepare(
    `${SESSION_SELECT_WITH_AUTHOR} WHERE s.status = 'published' ORDER BY s.published_at DESC`
  ).all(),
  db.prepare(
    "SELECT video_id, title, slug FROM youtube_videos WHERE slug != '' ORDER BY published_at DESC LIMIT 12"
  ).all(),
]);

const sessions: Session[] = ((sessionsRes.results || []) as any[]).map((row) => rowToSession(row));
const latestSession = sessions[0] || null;

const videos = ((videosRes.results || []) as any[]).map((r) => ({
  id: r.video_id as string,
  title: r.title as string,
  slug: r.slug as string,
}));

// CDN cache: serve cached for 1hr, revalidate in background
Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=3600, stale-while-revalidate=86400');

const websiteJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Daily Meditation Guide",
  "description": "Your daily guide to mindfulness and meditation. Curated audio journeys to help you focus, sleep, and reset.",
  "url": "https://dailymeditationguide.com",
  "inLanguage": "en"
});

let extraHead = `<script type="application/ld+json">${websiteJsonLd}</script>`;

// Preload hero LCP image
if (latestSession?.featuredImage) {
  extraHead += `<link rel="preload" as="image" href="${latestSession.featuredImage}" fetchpriority="high" />`;
}
---

<MainLayout
  title="Daily Meditation Guide"
  description="Your daily guide to mindfulness and meditation. Curated audio journeys to help you focus, sleep, and reset."
  canonical="https://dailymeditationguide.com/"
  extraHead={extraHead}
>
  <div class="space-y-20 transition-all duration-500 ease-in-out animate-[fade-enter_0.5s_ease-out]">

    {/* Hero Section */}
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-8">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-indigo-500/20 bg-indigo-500/5 text-indigo-400 text-xs font-medium tracking-wide">
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span>
          NEW SESSION ADDED
        </div>
        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-medium text-zinc-100 tracking-tight leading-[1.1]">
          Daily Meditation <br /> <span class="text-transparent bg-clip-text bg-gradient-to-r from-zinc-200 to-zinc-500">& Mindfulness Guide</span>
        </h1>
        <p class="text-lg text-zinc-500 font-light max-w-md leading-relaxed">
          Guided audio sessions for sleep, anxiety relief, and focus. Start your daily meditation practice with just five minutes.
        </p>
        <div class="flex flex-col sm:flex-row items-center gap-4 pt-2 w-full sm:w-auto">
          <a href="/video-sessions" class="group flex items-center justify-center gap-3 px-6 py-3 bg-zinc-100 hover:bg-white text-zinc-950 rounded-full font-medium text-sm transition-all hover:shadow-[0_0_20px_-5px_rgba(255,255,255,0.3)] w-full sm:w-auto">
            <iconify-icon icon="solar:play-circle-linear" width="20" stroke-width="1.5" class="text-zinc-950"></iconify-icon>
            Watch Video Sessions
          </a>
          <a href="/sessions" class="px-6 py-3 border border-white/10 hover:border-white/20 hover:bg-white/5 rounded-full text-zinc-300 text-sm font-medium transition-all w-full sm:w-auto text-center">
            Explore Library
          </a>
        </div>
      </div>

      {/* Latest Blog Featured Image */}
      <a
        href={latestSession?.slug ? `/session/${latestSession.slug}` : '#'}
        class="relative w-full h-[400px] lg:h-[500px] rounded-3xl overflow-hidden border border-white/[0.06] bg-zinc-900/40 flex items-center justify-center cursor-pointer group"
      >
        {latestSession?.featuredImage ? (
          <img
            src={latestSession.featuredImage}
            alt={latestSession.title}
            loading="eager"
            fetchpriority="high"
            decoding="async"
            width={600}
            height={500}
            sizes="(max-width: 1024px) calc(100vw - 48px), 50vw"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
        ) : (
          <>
            <div class="absolute w-72 h-72 bg-indigo-500/15 rounded-full blur-[100px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 animate-breathe"></div>
            <div class="absolute w-56 h-56 bg-teal-500/10 rounded-full blur-[80px] top-1/4 right-1/4 animate-breathe" style="animation-delay: 2s"></div>
          </>
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>

        <div class="relative z-10 text-center space-y-3 mt-auto p-8">
          <p class="font-display text-zinc-100 font-medium tracking-tight text-2xl drop-shadow-lg">
            {latestSession?.title || 'Afternoon Reset'}
          </p>
          <p class="text-zinc-300 text-xs uppercase tracking-widest">
            {latestSession ? `${latestSession.duration || '5 Min'} \u2022 ${latestSession.category}` : '15 Min \u2022 Focus'}
          </p>
        </div>
      </a>
    </section>

    {/* About Meditation Section - SEO Content */}
    <section class="max-w-4xl mx-auto space-y-8">
      <h2 class="font-display text-2xl md:text-3xl font-medium text-zinc-100 tracking-tight text-center">
        Your Path to Daily Mindfulness
      </h2>
      <div class="grid md:grid-cols-2 gap-8 text-zinc-400 text-sm leading-relaxed">
        <div class="space-y-4">
          <p>
            Daily Meditation Guide offers a curated library of guided meditation sessions designed for every level of experience. Whether you're new to mindfulness or have an established practice, our sessions provide the structure and guidance to help you build a consistent daily routine.
          </p>
          <p>
            Research from institutions like Harvard Medical School and the National Institutes of Health has shown that regular meditation practice can reduce stress, improve sleep quality, and enhance focus and emotional well-being. Even short sessions of 5 to 10 minutes can make a meaningful difference in your day.
          </p>
        </div>
        <div class="space-y-4">
          <p>
            Our library includes sessions for <strong class="text-zinc-300">sleep</strong> to help you wind down before bed, <strong class="text-zinc-300">anxiety relief</strong> practices with calming breathing techniques, <strong class="text-zinc-300">focus</strong> sessions for sharper concentration, and <strong class="text-zinc-300">nature soundscapes</strong> for ambient relaxation.
          </p>
          <p>
            Each session is paired with high-quality audio and thoughtfully written guides. Listen on your commute, during a lunch break, or as part of your morning routine. Start with just five minutes a day and build from there at your own pace.
          </p>
        </div>
      </div>
    </section>

    {/* Interactive content: filters + grid */}
    <HomeContent client:idle sessions={sessions} videos={videos} />
  </div>
</MainLayout>
