---
import MainLayout from '../layouts/MainLayout.astro';
import { rowToSession, SESSION_SELECT_WITH_AUTHOR } from '../lib/db';
import { thumbnailUrl, videoSlug, categorize, cleanDescription, VIDEO_CATEGORIES } from '../lib/videoCategories';
import type { Session } from '../types';

const db = Astro.locals.runtime.env.DB;
const { results } = await db.prepare(
  `${SESSION_SELECT_WITH_AUTHOR} WHERE s.status = 'published' ORDER BY s.published_at DESC`
).all();
const sessions: Session[] = (results || []).map((row: any) => rowToSession(row));

interface VideoRow { video_id: string; title: string; description: string | null; slug: string | null }
interface Video { id: string; title: string; slug: string }

const { results: videoRows } = await db
  .prepare('SELECT video_id, title, description, slug FROM youtube_videos ORDER BY published_at DESC')
  .all();

const videoSections: { key: string; label: string; videos: Video[] }[] = [];
{
  const grouped = new Map<string, { label: string; videos: Video[] }>();
  for (const row of (videoRows || []) as VideoRow[]) {
    const cleaned = cleanDescription(row.description ?? '');
    const cat = categorize(row.title, cleaned);
    const video: Video = {
      id: row.video_id,
      title: row.title,
      slug: row.slug || videoSlug(row.title, row.video_id),
    };
    const bucket = grouped.get(cat.key);
    if (bucket) bucket.videos.push(video);
    else grouped.set(cat.key, { label: cat.label, videos: [video] });
  }
  for (const cat of VIDEO_CATEGORIES) {
    const bucket = grouped.get(cat.key);
    if (bucket && bucket.videos.length > 0) {
      videoSections.push({ key: cat.key, label: cat.label, videos: bucket.videos });
      grouped.delete(cat.key);
    }
  }
  for (const [key, bucket] of grouped) {
    videoSections.push({ key, label: bucket.label, videos: bucket.videos });
  }
}
const totalVideos = videoSections.reduce((n, s) => n + s.videos.length, 0);

Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=3600, stale-while-revalidate=86400');

const siteUrl = 'https://dailymeditationguide.com';

const itemListJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Guided Meditation Sessions",
  "description": "Explore our library of guided meditation sessions and visual journeys.",
  "url": `${siteUrl}/sessions`,
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": sessions.length,
    "itemListElement": sessions.slice(0, 30).map((session, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `${siteUrl}/session/${session.slug}`,
      "name": session.title,
    }))
  }
});

const breadcrumbJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "Sessions", "item": `${siteUrl}/sessions` },
  ]
});

const extraHead = `<script type="application/ld+json">${itemListJsonLd}</script><script type="application/ld+json">${breadcrumbJsonLd}</script>`;
---

<MainLayout
  title="Guided Sessions"
  description="Explore our library of guided meditation sessions and visual journeys. Immerse yourself in curated meditations designed to help you find peace and clarity."
  canonical="https://dailymeditationguide.com/sessions"
  extraHead={extraHead}
>
  <div class="space-y-12 animate-[fade-enter_0.5s_ease-out]">
    <header class="space-y-6">
      <h1 class="font-display text-3xl md:text-5xl font-medium text-zinc-100 tracking-tight">
        Guided Meditation Sessions
      </h1>
      <p class="text-zinc-500 max-w-2xl text-lg">
        Immerse yourself in our curated collection of guided meditations and visual journeys designed to help you find peace and clarity.
      </p>
      <div class="text-zinc-400 max-w-3xl space-y-4 text-sm leading-relaxed border-t border-white/5 pt-6">
        <p>
          Our meditation library covers a range of practices to support your daily wellness routine. Whether you need help winding down for sleep, managing anxiety, sharpening focus, or simply finding a moment of calm, each session is crafted with care to guide you through a meaningful experience.
        </p>
        <p>
          Browse audio sessions led by experienced guides, or explore our collection of visual meditation videos featuring ambient soundscapes and nature imagery. Sessions range from quick 5-minute breathing exercises to immersive 30-minute guided practices, so you can find the right fit for your schedule and goals.
        </p>
      </div>
    </header>

    {/* Server-rendered session links for SEO crawlability */}
    {sessions.length > 0 && (
      <section class="space-y-6">
        <h2 class="font-display text-2xl font-medium text-zinc-100 tracking-tight">Meditation Sessions</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {sessions.map((session) => (
            <a
              href={`/session/${session.slug}`}
              class="group block bg-zinc-900/40 border border-white/[0.06] hover:border-white/[0.12] rounded-2xl overflow-hidden transition-all duration-300 hover:bg-zinc-800/40 hover:-translate-y-1"
            >
              {session.featuredImage && (
                <div class="relative h-48 w-full bg-zinc-800 overflow-hidden">
                  <img
                    src={session.featuredImage}
                    alt={session.title}
                    loading="lazy"
                    decoding="async"
                    width={400}
                    height={192}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </div>
              )}
              <div class="p-5 space-y-2">
                <h3 class="font-display text-zinc-200 font-medium tracking-tight line-clamp-2 group-hover:text-white transition-colors">
                  {session.title}
                </h3>
                {session.description && (
                  <p class="text-zinc-500 text-sm line-clamp-2">{session.description}</p>
                )}
                <div class="flex items-center gap-3 text-xs text-zinc-500 pt-1">
                  {session.category && <span class="px-2 py-0.5 rounded-full bg-white/5 border border-white/5">{session.category}</span>}
                  {session.duration && <span>{session.duration}</span>}
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* YouTube video sessions, categorized */}
    {totalVideos > 0 && (
      <div class="space-y-10">
        <div class="flex items-baseline justify-between border-b border-white/5 pb-3">
          <h2 class="font-display text-2xl font-medium text-zinc-100 tracking-tight">Video Sessions</h2>
          <span class="text-xs text-zinc-500">{totalVideos} sessions</span>
        </div>

        <nav aria-label="Video categories" class="flex flex-wrap gap-2">
          {videoSections.map((section) => (
            <a
              href={`#${section.key}`}
              class="px-3 py-1.5 text-xs rounded-full bg-white/5 border border-white/10 text-zinc-300 hover:bg-white/10 hover:text-white transition-colors"
            >
              {section.label}
              <span class="text-zinc-500 ml-1">({section.videos.length})</span>
            </a>
          ))}
        </nav>

        {videoSections.map((section) => (
          <section id={section.key} class="space-y-6 scroll-mt-24">
            <div class="flex items-baseline justify-between">
              <h3 class="font-display text-xl font-medium text-zinc-100 tracking-tight">{section.label}</h3>
              <span class="text-xs text-zinc-500">{section.videos.length} sessions</span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {section.videos.map((video) => (
                <a
                  href={`/video-sessions/${video.slug}`}
                  class="group block bg-zinc-900/40 border border-white/[0.06] hover:border-white/[0.12] rounded-2xl overflow-hidden transition-all duration-300 hover:bg-zinc-800/40 hover:-translate-y-1 hover:shadow-lg hover:shadow-black/20"
                >
                  <div class="relative aspect-video w-full overflow-hidden bg-zinc-800">
                    <img
                      src={thumbnailUrl(video.id, 'hq')}
                      alt={video.title}
                      loading="lazy"
                      decoding="async"
                      width={480}
                      height={360}
                      class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                      <div class="w-14 h-14 bg-white/10 backdrop-blur-md rounded-full flex items-center justify-center text-white border border-white/20">
                        <iconify-icon icon="solar:play-linear" width="28" class="ml-1"></iconify-icon>
                      </div>
                    </div>
                  </div>
                  <div class="p-5">
                    <h4 class="font-display text-zinc-100 font-medium tracking-tight line-clamp-2 group-hover:text-white transition-colors">
                      {video.title}
                    </h4>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    )}
  </div>
</MainLayout>
