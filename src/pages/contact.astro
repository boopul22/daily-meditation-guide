---
import MainLayout from '../layouts/MainLayout.astro';
import ContactForm from '../components/ContactForm';
---

<MainLayout
  title="Contact Us"
  description="Get in touch with the Daily Meditation Guide team. We're here to help with any questions, suggestions, or feedback about our meditation sessions."
  canonical="https://dailymeditationguide.com/contact"
>
  <div class="min-h-screen animate-[fade-enter_0.5s_ease-out]">

    <!-- Background Ambience -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-1/4 left-1/3 w-[600px] h-[600px] bg-indigo-500/5 rounded-full blur-[120px]"></div>
      <div class="absolute inset-0 bg-[url('/noise.svg')] opacity-20"></div>
    </div>

    <div class="relative container mx-auto px-6 py-20 max-w-5xl">
      <div class="grid lg:grid-cols-2 gap-16 items-start">

        <!-- Header & Info -->
        <div class="space-y-10">
          <div class="space-y-6">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/10 bg-white/5 text-zinc-400 text-xs font-medium tracking-wide">
              <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
              SUPPORT
            </div>
            <h1 class="font-display text-5xl md:text-6xl font-medium text-zinc-100 tracking-tight leading-tight">
              We'd love to <br />
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-200 to-indigo-300">hear from you.</span>
            </h1>
            <p class="text-lg text-zinc-400 leading-relaxed max-w-md">
              Have questions about our sessions, suggestions for new sounds, or just want to say hello? We're here to help.
            </p>
          </div>

          <div class="space-y-6">
            <a href="mailto:blog.boopul@gmail.com" class="group flex items-center gap-4 p-4 rounded-2xl bg-zinc-900/40 border border-white/5 hover:border-white/10 hover:bg-zinc-900/60 transition-all duration-300">
              <div class="w-12 h-12 rounded-full bg-indigo-500/10 flex items-center justify-center text-indigo-400 group-hover:scale-110 transition-transform">
                <iconify-icon icon="solar:letter-linear" width="24"></iconify-icon>
              </div>
              <div>
                <p class="text-sm text-zinc-500">Email Support</p>
                <p class="text-zinc-200 font-medium">blog.boopul@gmail.com</p>
              </div>
            </a>

            <a href="#" class="group flex items-center gap-4 p-4 rounded-2xl bg-zinc-900/40 border border-white/5 hover:border-white/10 hover:bg-zinc-900/60 transition-all duration-300">
              <div class="w-12 h-12 rounded-full bg-teal-500/10 flex items-center justify-center text-teal-400 group-hover:scale-110 transition-transform">
                <iconify-icon icon="brandico:twitter-bird" width="20"></iconify-icon>
              </div>
              <div>
                <p class="text-sm text-zinc-500">Follow Updates</p>
                <p class="text-zinc-200 font-medium">@DailyMediGuide</p>
              </div>
            </a>
          </div>
        </div>

        <!-- Contact Form (React island for form state) -->
        <ContactForm client:load />

      </div>
    </div>
  </div>
</MainLayout>
