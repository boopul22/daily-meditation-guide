---
import MainLayout from '../../layouts/MainLayout.astro';
import DetailInteractive from '../../components/DetailInteractive';
import { rowToSession } from '../../lib/db';
import { processContentForTOC } from '../../utils/tocUtils';
import type { Session } from '../../types';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

const db = Astro.locals.runtime.env.DB;

// Fetch session by slug
const row = await db.prepare(
  "SELECT * FROM sessions WHERE slug = ? AND status = 'published'"
).bind(slug).first();

if (!row) {
  return Astro.redirect('/404');
}

const session: Session = rowToSession(row);

// Process content for TOC (server-side with regex)
const { processedContent, headings } = session.fullContent
  ? processContentForTOC(session.fullContent)
  : { processedContent: '', headings: [] };

// Fetch related sessions
let relatedSessions: Session[] = [];
if (session.relatedSessions && session.relatedSessions.length > 0) {
  const placeholders = session.relatedSessions.map(() => '?').join(',');
  const { results } = await db.prepare(
    `SELECT * FROM sessions WHERE id IN (${placeholders}) AND status = 'published'`
  ).bind(...session.relatedSessions).all();
  relatedSessions = (results || []).map((r: any) => rowToSession(r));
}

// Build SEO meta
const siteUrl = 'https://dailymeditationguide.com';
const pageUrl = `${siteUrl}/session/${session.slug}`;
const pageTitle = session.title;
const pageDescription = session.description || `Listen to ${session.title} by ${session.author}. A ${session.duration} ${session.category} meditation session.`;
const pageImage = session.featuredImage || '/og-image.jpg';

// Article JSON-LD
const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": pageTitle,
  "description": pageDescription,
  "url": pageUrl,
  "image": pageImage.startsWith('http') ? pageImage : `${siteUrl}${pageImage}`,
  ...(session.category && { "articleSection": session.category }),
  ...(session.author && {
    "author": {
      "@type": "Person",
      "name": session.author
    }
  }),
  ...(session.publishedAt && { "datePublished": session.publishedAt }),
  ...(session.updatedAt && { "dateModified": session.updatedAt }),
  "publisher": {
    "@type": "Organization",
    "name": "Daily Meditation Guide",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/favicon-192x192.png`
    }
  }
});

// Breadcrumb JSON-LD
const breadcrumbJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl + "/" },
    { "@type": "ListItem", "position": 2, "name": "Sessions", "item": siteUrl + "/sessions" },
    { "@type": "ListItem", "position": 3, "name": session.title, "item": pageUrl }
  ]
});

// FAQ JSON-LD (optional)
const hasFaq = session.faqItems && session.faqItems.length > 0 && session.faqItems.some(f => f.question && f.answer);
const faqJsonLd = hasFaq ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": session.faqItems.filter(f => f.question && f.answer).map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.answer
    }
  }))
}) : '';

// Combine all JSON-LD scripts
let extraHead = `<script type="application/ld+json">${articleJsonLd}</script>`;
extraHead += `<script type="application/ld+json">${breadcrumbJsonLd}</script>`;
if (faqJsonLd) {
  extraHead += `<script type="application/ld+json">${faqJsonLd}</script>`;
}
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonical={pageUrl}
  ogType="article"
  ogImage={pageImage.startsWith('http') ? pageImage : `${siteUrl}${pageImage}`}
  extraHead={extraHead}
>
  <div class="animate-[fade-enter_0.5s_ease-out]">
    {/* Back Button */}
    <a href="/" class="group flex items-center gap-2 text-zinc-500 hover:text-zinc-200 mb-8 transition-colors">
      <iconify-icon icon="solar:arrow-left-linear" class="group-hover:-translate-x-1 transition-transform"></iconify-icon>
      <span class="text-sm font-medium">Back to Sessions</span>
    </a>

    <DetailInteractive
      client:load
      session={session}
      processedContent={processedContent}
      headings={headings}
      relatedSessions={relatedSessions}
    />
  </div>
</MainLayout>
