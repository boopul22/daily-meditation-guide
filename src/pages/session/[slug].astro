---
import MainLayout from '../../layouts/MainLayout.astro';
import DetailInteractive from '../../components/DetailInteractive';
import { rowToSession, SESSION_SELECT_WITH_AUTHOR } from '../../lib/db';
import { optimizedImage, optimizedSrcSet, optimizedImageAbs } from '../../lib/image';
import { processContentForTOC } from '../../utils/tocUtils';
import type { Session } from '../../types';

const { slug } = Astro.params;
const db = Astro.locals.runtime.env.DB;

let session: Session | null = null;

if (slug) {
  const row = await db.prepare(
    `${SESSION_SELECT_WITH_AUTHOR} WHERE s.slug = ? AND s.status = 'published'`
  ).bind(slug).first();
  if (row) {
    session = rowToSession(row);
  }
}

if (!session) {
  Astro.response.status = 404;
  Astro.response.headers.set('X-Robots-Tag', 'noindex, nofollow');
}

// CDN cache only for valid sessions
if (session) {
  Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=3600, stale-while-revalidate=86400');
}

// Process content for TOC (server-side with regex)
const { processedContent, headings } = session?.fullContent
  ? processContentForTOC(session.fullContent)
  : { processedContent: '', headings: [] };

// Fetch related sessions
let relatedSessions: Session[] = [];
if (session?.relatedSessions && session.relatedSessions.length > 0) {
  const placeholders = session.relatedSessions.map(() => '?').join(',');
  const { results } = await db.prepare(
    `${SESSION_SELECT_WITH_AUTHOR} WHERE s.id IN (${placeholders}) AND s.status = 'published'`
  ).bind(...session.relatedSessions).all();
  relatedSessions = (results || []).map((r: any) => rowToSession(r));
}

// Build SEO meta
const siteUrl = 'https://dailymeditationguide.com';
const pageUrl = session ? `${siteUrl}/session/${session.slug}` : siteUrl;
const pageTitle = session?.title || 'Session Not Found';
const pageDescription = session
  ? (session.description || `Listen to ${session.title} by ${session.author}. A ${session.duration} ${session.category} meditation session.`)
  : 'The meditation session you are looking for could not be found.';
const ogImageAbs = optimizedImageAbs(session?.featuredImage, { width: 1200 }, '/og-image.jpg');

// Build JSON-LD only for valid sessions
let extraHead = '';
if (session) {
  // Hero image preload for LCP (transformed + responsive)
  if (session.featuredImage) {
    const lcpWidths = [400, 600, 800];
    const lcpSrc = optimizedImage(session.featuredImage, { width: 600, height: 312, fit: 'cover' });
    const lcpSrcSet = optimizedSrcSet(session.featuredImage, lcpWidths, { fit: 'cover' });
    if (lcpSrcSet) {
      extraHead += `<link rel="preload" as="image" href="${lcpSrc}" imagesrcset="${lcpSrcSet}" imagesizes="(max-width: 1024px) calc(100vw - 48px), 400px" fetchpriority="high" />`;
    } else {
      extraHead += `<link rel="preload" as="image" href="${lcpSrc}" fetchpriority="high" />`;
    }
  }

  // Article JSON-LD with AudioObject
  const articleJsonLd = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": pageTitle,
    "description": pageDescription,
    "url": pageUrl,
    "mainEntityOfPage": pageUrl,
    "image": ogImageAbs,
    ...(session.category && { "articleSection": session.category }),
    ...(session.author && {
      "author": {
        "@type": "Person",
        "name": session.author,
        ...(session.authorPicture && { "image": optimizedImageAbs(session.authorPicture, { width: 240 }) }),
        "url": `${siteUrl}/about`
      }
    }),
    "datePublished": session.publishedAt || session.createdAt || new Date().toISOString(),
    ...(session.updatedAt && { "dateModified": session.updatedAt }),
    "publisher": {
      "@type": "Organization",
      "name": "Daily Meditation Guide",
      "logo": {
        "@type": "ImageObject",
        "url": `${siteUrl}/favicon-192x192.png`
      }
    },
    ...(session.audioUrl && {
      "audio": {
        "@type": "AudioObject",
        "contentUrl": session.audioUrl.startsWith('http') ? session.audioUrl : `${siteUrl}${session.audioUrl}`,
        "name": session.title,
        "description": pageDescription,
        ...(session.durationSec && { "duration": `PT${Math.floor(session.durationSec / 60)}M${session.durationSec % 60}S` }),
        "encodingFormat": "audio/mpeg"
      }
    })
  });

  // Breadcrumb JSON-LD
  const breadcrumbJsonLd = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl + "/" },
      { "@type": "ListItem", "position": 2, "name": "Sessions", "item": siteUrl + "/sessions" },
      { "@type": "ListItem", "position": 3, "name": session.title, "item": pageUrl }
    ]
  });

  extraHead += `<script type="application/ld+json">${articleJsonLd}</script>`;
  extraHead += `<script type="application/ld+json">${breadcrumbJsonLd}</script>`;
}
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonical={session ? pageUrl : undefined}
  ogType={session ? "article" : undefined}
  ogImage={session ? ogImageAbs : undefined}
  noindex={!session}
  extraHead={extraHead}
  articlePublishedTime={session?.publishedAt || session?.createdAt || undefined}
  articleModifiedTime={session?.updatedAt || undefined}
>
  {session ? (
    <div class="animate-[fade-enter_0.5s_ease-out]">
      {/* Visible Breadcrumb Navigation */}
      <nav aria-label="Breadcrumb" class="mb-6 text-sm">
        <ol class="flex items-center gap-2 text-zinc-500">
          <li><a href="/" class="hover:text-zinc-300 transition-colors">Home</a></li>
          <li><span class="text-zinc-600">/</span></li>
          <li><a href="/sessions" class="hover:text-zinc-300 transition-colors">Sessions</a></li>
          <li><span class="text-zinc-600">/</span></li>
          <li class="text-zinc-400 truncate max-w-[200px]">{session.title}</li>
        </ol>
      </nav>

      <DetailInteractive
        client:idle
        session={session}
        processedContent={processedContent}
        headings={headings}
        relatedSessions={relatedSessions}
      />
    </div>
  ) : (
    <div class="flex flex-col items-center justify-center min-h-[60vh] text-center space-y-8 animate-[fade-enter_0.5s_ease-out]">
      <div class="relative">
        <div class="absolute inset-0 bg-indigo-500/20 blur-[60px] rounded-full animate-breathe"></div>
        <h1 class="font-display relative text-9xl font-bold text-transparent bg-clip-text bg-gradient-to-b from-zinc-200 to-zinc-800 tracking-tighter">
          404
        </h1>
      </div>
      <div class="space-y-4 max-w-md mx-auto">
        <h2 class="font-display text-2xl font-medium text-zinc-200">Session not found</h2>
        <p class="text-zinc-500">The meditation session you're looking for doesn't exist or has been removed.</p>
      </div>
      <a
        href="/sessions"
        class="group flex items-center gap-2 px-6 py-3 bg-zinc-100 hover:bg-white text-zinc-950 rounded-full font-medium text-sm transition-all hover:shadow-[0_0_20px_-5px_rgba(255,255,255,0.3)]"
      >
        Browse Sessions
      </a>
    </div>
  )}
</MainLayout>
