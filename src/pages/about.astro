---
export const prerender = true;
import MainLayout from '../layouts/MainLayout.astro';

const coreValues = [
  { title: "Privacy First", desc: "I prioritize user privacy and data protection above all else.", icon: "solar:shield-check-linear", color: "text-blue-400", bg: "bg-blue-500/10" },
  { title: "User-Centric", desc: "Every feature is designed with you in mind, keeping things simple and useful.", icon: "solar:heart-angle-linear", color: "text-red-400", bg: "bg-red-500/10" },
  { title: "Quality Assurance", desc: "I maintain high standards for performance, security, and experience.", icon: "solar:medal-ribbon-linear", color: "text-amber-400", bg: "bg-amber-500/10" },
  { title: "Global Access", desc: "Building tools that are accessible to everyone, regardless of location.", icon: "solar:globe-linear", color: "text-purple-400", bg: "bg-purple-500/10" },
  { title: "Community Focus", desc: "I value feedback and actively seek to improve based on user needs.", icon: "solar:users-group-rounded-linear", color: "text-green-400", bg: "bg-green-500/10" },
  { title: "Speed & Reliability", desc: "Optimized for performance to ensure seamless experiences.", icon: "solar:bolt-linear", color: "text-indigo-400", bg: "bg-indigo-500/10" },
];

const whatIDo = [
  { title: "Apps & Tools", desc: "Build small apps, tools, and websites using AI, no-code, and lightweight tech", icon: "solar:code-square-linear" },
  { title: "AI Workflows", desc: "Experiment with AI workflows to automate ideas and simplify complex tasks", icon: "solar:magic-stick-3-linear" },
  { title: "Digital Assets", desc: "Design and contribute to digital assets and creative projects", icon: "solar:palette-linear" },
  { title: "Self-Improvement", desc: "Create content around discipline, fitness, self-improvement, and stoic thinking", icon: "solar:dumbbell-large-linear" },
  { title: "Discipline & Fitness", desc: "Train regularly, follow structured routines, and treat physical health as a foundation", icon: "solar:running-linear" },
  { title: "Communication", desc: "Continuously improve English communication and clarity of thought", icon: "solar:chat-round-line-linear" },
];

const projects = [
  { name: "ExtractPics", desc: "Extract and download images from any website instantly. Supports batch processing and smart filtering.", link: "https://www.extractpics.com/" },
  { name: "ImageToURL", desc: "Convert any image to URL instantly. Free image hosting with global CDN delivery.", link: "https://imagetourl.cloud/" },
  { name: "StoriesPDF", desc: "Discover and download captivated PDF stories for all ages.", link: "#" },
  { name: "TamilKathai", desc: "A collection of wonderful Tamil stories and cultural narratives.", link: "#" },
];

const connectLinks = [
  { label: "GitHub", val: "Projects & Code", icon: "brandico:github", link: "https://github.com/boopul22" },
  { label: "Instagram", val: "Life, Fitness & AI", icon: "brandico:instagram", link: "https://www.instagram.com/bipul.skill/" },
  { label: "Personal Website", val: "bipul.online", icon: "solar:globe-linear", link: "https://bipul.online/" },
  { label: "Email", val: "blog.boopul@gmail.com", icon: "solar:letter-linear", link: "mailto:blog.boopul@gmail.com" },
];

const philosophy = ["Start small", "Stay consistent", "Build quietly", "Let results make the noise"];
---

<MainLayout
  title="About | Meditation & Mindfulness"
  description="Learn about Daily Meditation Guide — your daily source for guided meditations, ambient soundscapes, and mindfulness resources, created by Bipul Kumar."
  canonical="https://dailymeditationguide.com/about"
  extraHead={`<script type="application/ld+json">${JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    "mainEntity": {
      "@type": "Person",
      "name": "Bipul Kumar",
      "description": "Indie developer, designer, and mindfulness advocate from India. Founder of Daily Meditation Guide.",
      "jobTitle": "Founder & Developer",
      "url": "https://dailymeditationguide.com/about",
      "worksFor": {
        "@type": "Organization",
        "name": "Daily Meditation Guide",
        "url": "https://dailymeditationguide.com"
      }
    }
  })}</script><script type="application/ld+json">${JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dailymeditationguide.com/" },
      { "@type": "ListItem", "position": 2, "name": "About", "item": "https://dailymeditationguide.com/about" }
    ]
  })}</script>`}
>
  <div class="min-h-screen animate-[fade-enter_0.5s_ease-out]">

    <!-- Background Ambience -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-0 right-1/4 w-[500px] h-[500px] bg-indigo-500/10 rounded-full blur-[100px] animate-pulse"></div>
      <div class="absolute bottom-0 left-1/4 w-[400px] h-[400px] bg-teal-500/10 rounded-full blur-[80px] animate-pulse" style="animation-delay: 2s;"></div>
    </div>

    <div class="relative container mx-auto px-6 py-20 max-w-4xl space-y-24">

      <!-- Hero Section -->
      <section class="text-center space-y-8">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/10 bg-white/5 text-zinc-400 text-xs font-medium tracking-wide">
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-500"></span>
          ABOUT
        </div>

        <h1 class="font-display text-5xl md:text-7xl font-medium text-zinc-100 tracking-tight leading-[1.1]">
          Hi, I'm <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-300 via-purple-300 to-indigo-300 animate-shimmer bg-[length:200%_auto]">Bipul Kumar</span>
        </h1>

        <p class="text-xl text-zinc-400 max-w-2xl mx-auto leading-relaxed font-light">
          I'm an indie developer and designer from India. I believe that consistency beats talent and action beats intention.
        </p>
      </section>

      <!-- About the Site -->
      <section class="space-y-8">
        <h2 class="font-display text-3xl font-medium text-zinc-100 tracking-tight">About Daily Meditation Guide</h2>
        <div class="p-8 rounded-3xl border border-white/5 bg-zinc-900/40 backdrop-blur-sm space-y-6">
          <p class="text-zinc-400 leading-relaxed text-lg">
            Daily Meditation Guide is a curated platform offering guided meditation sessions, ambient soundscapes, and mindfulness resources designed to help you find focus, calm, and clarity in your everyday life.
          </p>
          <p class="text-zinc-400 leading-relaxed text-lg">
            Whether you're looking to manage stress, improve sleep, sharpen your focus, or simply take a moment to breathe, our sessions are crafted to support your personal wellness journey. From short 5-minute breathing exercises to deep 30-minute guided meditations, there's something for everyone.
          </p>
          <p class="text-zinc-400 leading-relaxed text-lg">
            Our mission is simple: <span class="text-zinc-200">make mindfulness and mental clarity accessible to everyone</span>, regardless of experience level or background. New sessions are added regularly to keep your practice fresh and engaging.
          </p>
        </div>
      </section>

      <!-- My Story -->
      <section class="space-y-8">
        <h2 class="font-display text-3xl font-medium text-zinc-100 tracking-tight">My Story</h2>
        <div class="p-8 rounded-3xl border border-white/5 bg-zinc-900/40 backdrop-blur-sm">
          <p class="text-zinc-400 leading-relaxed text-lg mb-6">
            My journey hasn't been smooth or privileged. I grew up with limited resources, struggled academically in my early years, and paid my own college fees through persistence and self-learning. Those experiences shaped how I think, work, and build today — with clarity, resilience, and focus on long-term growth.
          </p>
          <p class="text-zinc-400 leading-relaxed text-lg">
            I built Daily Meditation Guide to share the tools that helped me find focus and stillness amidst the chaos. It's a reflection of my belief that mental clarity shouldn't be a luxury, but a fundamental need.
          </p>
        </div>
      </section>

      <!-- Core Values -->
      <section class="space-y-12">
        <div class="text-center max-w-2xl mx-auto space-y-4">
          <h2 class="font-display text-3xl font-medium text-zinc-100 tracking-tight">Core Values</h2>
          <p class="text-zinc-500">The principles that guide my work and life.</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {coreValues.map((val) => (
            <div class="group p-6 rounded-2xl border border-white/5 bg-zinc-900/40 hover:bg-zinc-900/60 transition-all duration-300 text-center">
              <div class={`w-12 h-12 rounded-full ${val.bg} flex items-center justify-center ${val.color} mx-auto mb-4 group-hover:scale-110 transition-transform`}>
                <iconify-icon icon={val.icon} width="24"></iconify-icon>
              </div>
              <h3 class="text-lg font-medium text-zinc-200 mb-2">{val.title}</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">{val.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- What I Do -->
      <section class="space-y-8">
        <div class="text-center max-w-2xl mx-auto space-y-4">
          <h2 class="font-display text-3xl font-medium text-zinc-100 tracking-tight">What I Do</h2>
          <p class="text-zinc-500">I enjoy working at the intersection of AI, no-code tools, design, automation, and personal development</p>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          {whatIDo.map((item) => (
            <div class="group p-6 rounded-2xl border border-white/5 bg-zinc-900/40 hover:bg-zinc-900/60 transition-all duration-300">
              <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-zinc-300 mb-4 group-hover:scale-110 transition-transform">
                <iconify-icon icon={item.icon} width="20"></iconify-icon>
              </div>
              <h3 class="text-lg font-medium text-zinc-200 mb-2">{item.title}</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
        <p class="text-center text-zinc-500 italic mt-8">"I prefer practical execution over theory, clean systems over noise, and steady progress over shortcuts."</p>
      </section>

      <!-- Philosophy -->
      <section class="py-12 border-y border-white/5">
        <h2 class="font-display text-center text-2xl font-medium text-zinc-200 mb-12">Personal Philosophy</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          {philosophy.map((text) => (
            <div class="space-y-4 group">
              <div class="w-2 h-2 rounded-full bg-indigo-500 mx-auto group-hover:scale-150 transition-transform"></div>
              <p class="text-zinc-300 font-medium tracking-tight">{text}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Other Projects -->
      <section class="space-y-8">
        <h2 class="font-display text-3xl font-medium text-zinc-100 tracking-tight">My Other Projects</h2>
        <div class="grid md:grid-cols-2 gap-6">
          {projects.map((project) => (
            <a href={project.link} class="block p-8 rounded-3xl border border-white/5 bg-zinc-900/20 hover:bg-zinc-900/40 transition-all duration-300 group">
              <div class="flex justify-between items-start mb-4">
                <h3 class="text-xl font-medium text-zinc-200 group-hover:text-indigo-300 transition-colors">{project.name}</h3>
                <iconify-icon icon="solar:arrow-right-up-linear" class="text-zinc-500 group-hover:text-zinc-300 transition-colors"></iconify-icon>
              </div>
              <p class="text-zinc-400 text-sm leading-relaxed">{project.desc}</p>
            </a>
          ))}
        </div>
      </section>

      <!-- Let's Connect -->
      <section class="space-y-8">
        <h2 class="font-display text-3xl font-medium text-zinc-100 tracking-tight">Let's Connect</h2>
        <p class="text-zinc-400">If you're interested in AI, no-code tools, creative technology, fitness discipline, or personal growth — welcome, you're in the right place.</p>

        <div class="grid md:grid-cols-2 gap-4">
          {connectLinks.map((item) => (
            <a href={item.link} class="flex items-center gap-4 p-4 rounded-xl border border-white/5 bg-zinc-900/30 hover:bg-zinc-900/50 transition-colors">
              <div class="w-10 h-10 rounded-lg bg-zinc-900 flex items-center justify-center text-zinc-400">
                <iconify-icon icon={item.icon} width="20"></iconify-icon>
              </div>
              <div>
                <p class="text-zinc-200 font-medium text-sm">{item.label}</p>
                <p class="text-zinc-500 text-xs">{item.val}</p>
              </div>
            </a>
          ))}
        </div>
      </section>

    </div>
  </div>
</MainLayout>
