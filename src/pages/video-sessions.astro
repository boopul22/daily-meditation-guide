---
import MainLayout from '../layouts/MainLayout.astro';
import { VIDEO_CATEGORIES, categorize, thumbnailUrl, videoSlug } from '../lib/videoCategories';

interface VideoRow {
  video_id: string;
  title: string;
  description: string;
  slug: string;
  published_at: string;
}

const db = (Astro.locals as any).runtime.env.DB;
const { results } = await db
  .prepare(
    'SELECT video_id, title, description, slug, published_at FROM youtube_videos ORDER BY published_at DESC'
  )
  .all();

const rows = (results || []) as VideoRow[];

interface Video {
  id: string;
  title: string;
  description: string;
  slug: string;
  excerpt: string;
}

function excerpt(text: string, max = 160): string {
  const cleaned = text.replace(/\s+/g, ' ').trim();
  if (cleaned.length <= max) return cleaned;
  const cut = cleaned.slice(0, max);
  const lastSpace = cut.lastIndexOf(' ');
  return (lastSpace > 60 ? cut.slice(0, lastSpace) : cut) + '…';
}

// Group by category
const grouped = new Map<string, { label: string; videos: Video[] }>();

for (const row of rows) {
  const cat = categorize(row.title, row.description);
  const slug = row.slug || videoSlug(row.title, row.video_id);
  const video: Video = {
    id: row.video_id,
    title: row.title,
    description: row.description ?? '',
    slug,
    excerpt: excerpt(row.description ?? ''),
  };
  const bucket = grouped.get(cat.key);
  if (bucket) {
    bucket.videos.push(video);
  } else {
    grouped.set(cat.key, { label: cat.label, videos: [video] });
  }
}

// Ordered sections: defined order first, any remaining at end
const orderedSections: { key: string; label: string; videos: Video[] }[] = [];
for (const cat of VIDEO_CATEGORIES) {
  const bucket = grouped.get(cat.key);
  if (bucket && bucket.videos.length > 0) {
    orderedSections.push({ key: cat.key, label: cat.label, videos: bucket.videos });
    grouped.delete(cat.key);
  }
}
for (const [key, bucket] of grouped) {
  orderedSections.push({ key, label: bucket.label, videos: bucket.videos });
}

Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=300, s-maxage=3600, stale-while-revalidate=86400'
);

const siteUrl = 'https://dailymeditationguide.com';
const pageUrl = `${siteUrl}/video-sessions`;

const itemListJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Video Meditation Sessions',
  description: 'A complete, categorized library of guided meditation videos — sleep, anxiety, morning, breathwork, focus and more.',
  url: pageUrl,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: rows.length,
    itemListElement: rows.slice(0, 100).map((v, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: v.title,
      url: `${siteUrl}/video-sessions/${v.slug || videoSlug(v.title, v.video_id)}`,
    })),
  },
});

const breadcrumbJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Video Sessions', item: pageUrl },
  ],
});

const extraHead = `<script type="application/ld+json">${itemListJsonLd}</script><script type="application/ld+json">${breadcrumbJsonLd}</script>`;
---

<MainLayout
  title="Video Meditation Sessions"
  description="Every guided meditation video from Daily Meditation Guide — categorized by sleep, anxiety, morning, breathwork, focus and more. Watch with full titles and descriptions."
  canonical={pageUrl}
  extraHead={extraHead}
>
  <div class="space-y-12 animate-[fade-enter_0.5s_ease-out]">
    <header class="space-y-6">
      <h1 class="font-display text-3xl md:text-5xl font-medium text-zinc-100 tracking-tight">
        Video Meditation Sessions
      </h1>
      <p class="text-zinc-500 max-w-2xl text-lg">
        Every guided meditation video, grouped by theme. Tap a category to jump to it, tap any session to watch.
      </p>

      {/* Category anchor nav */}
      <nav aria-label="Video categories" class="flex flex-wrap gap-2 pt-2">
        {orderedSections.map((section) => (
          <a
            href={`#${section.key}`}
            class="px-3 py-1.5 text-xs rounded-full bg-white/5 border border-white/10 text-zinc-300 hover:bg-white/10 hover:text-white transition-colors"
          >
            {section.label}
            <span class="text-zinc-500 ml-1">({section.videos.length})</span>
          </a>
        ))}
      </nav>

      <div class="text-xs text-zinc-500 pt-1">{rows.length} total sessions</div>
    </header>

    {orderedSections.map((section) => (
      <section id={section.key} class="space-y-6 scroll-mt-24">
        <div class="flex items-baseline justify-between border-b border-white/5 pb-3">
          <h2 class="font-display text-2xl font-medium text-zinc-100 tracking-tight">
            {section.label}
          </h2>
          <span class="text-xs text-zinc-500">{section.videos.length} sessions</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {section.videos.map((video) => (
            <a
              href={`/video-sessions/${video.slug}`}
              class="group block bg-zinc-900/40 border border-white/[0.06] hover:border-white/[0.12] rounded-2xl overflow-hidden transition-all duration-300 hover:bg-zinc-800/40 hover:-translate-y-1 hover:shadow-lg hover:shadow-black/20"
            >
              <div class="relative aspect-video w-full overflow-hidden bg-zinc-800">
                <img
                  src={thumbnailUrl(video.id, 'max')}
                  alt={video.title}
                  loading="lazy"
                  decoding="async"
                  width={1280}
                  height={720}
                  onerror={`this.onerror=null;this.src='${thumbnailUrl(video.id, 'hq')}'`}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <div class="w-14 h-14 bg-white/10 backdrop-blur-md rounded-full flex items-center justify-center text-white border border-white/20">
                    <iconify-icon icon="solar:play-linear" width="28" class="ml-1"></iconify-icon>
                  </div>
                </div>
              </div>

              <div class="p-5 space-y-2">
                <h3 class="font-display text-zinc-100 font-medium tracking-tight line-clamp-2 group-hover:text-white transition-colors">
                  {video.title}
                </h3>
                {video.excerpt && (
                  <p class="text-zinc-500 text-sm line-clamp-2">{video.excerpt}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</MainLayout>
